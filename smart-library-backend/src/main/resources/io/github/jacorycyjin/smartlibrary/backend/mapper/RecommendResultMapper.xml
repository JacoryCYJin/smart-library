<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="io.github.jacorycyjin.smartlibrary.backend.mapper.RecommendResultMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="io.github.jacorycyjin.smartlibrary.backend.entity.RecommendResult">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="resource_id" property="resourceId"/>
        <result column="score" property="score"/>
        <result column="reason" property="reason"/>
        <result column="ctime" property="ctime"/>
    </resultMap>

    <!-- 根据用户ID查询推荐列表 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT id, user_id, resource_id, score, reason, ctime
        FROM recommend_result
        WHERE user_id = #{userId}
        ORDER BY score DESC
        LIMIT #{limit}
    </select>

    <!-- 查询推荐覆盖的用户数 -->
    <select id="countUsersWithRecommendations" resultType="java.lang.Integer">
        SELECT COUNT(DISTINCT user_id)
        FROM recommend_result
    </select>

</mapper>
