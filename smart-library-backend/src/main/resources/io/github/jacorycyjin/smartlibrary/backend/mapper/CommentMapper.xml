<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.jacorycyjin.smartlibrary.backend.mapper.CommentMapper">

    <!-- 评论结果映射（管理员用，包含用户名和资源标题） -->
    <resultMap id="CommentResultMap" type="io.github.jacorycyjin.smartlibrary.backend.entity.Comment">
        <id column="id" property="id"/>
        <result column="comment_id" property="commentId"/>
        <result column="user_id" property="userId"/>
        <result column="resource_id" property="resourceId"/>
        <result column="content" property="content"/>
        <result column="score" property="score"/>
        <result column="like_count" property="likeCount"/>
        <result column="audit_status" property="auditStatus"/>
        <result column="rejection_reason" property="rejectionReason"/>
        <result column="ctime" property="ctime"/>
        <result column="mtime" property="mtime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 管理员评论结果映射（包含用户名和资源标题） -->
    <resultMap id="AdminCommentResultMap" type="io.github.jacorycyjin.smartlibrary.backend.entity.Comment" extends="CommentResultMap">
        <result column="username" property="username"/>
        <result column="resource_title" property="resourceTitle"/>
    </resultMap>

    <!-- 根据资源ID查询已通过审核的评论列表（支持分页） -->
    <select id="selectByResourceId" resultMap="CommentResultMap">
        SELECT *
        FROM comment
        WHERE resource_id = #{resourceId}
          AND audit_status = 1
          AND deleted = 0
        ORDER BY ctime DESC
    </select>

    <!-- 统计资源的评论总数 -->
    <select id="countByResourceId" resultType="int">
        SELECT COUNT(*)
        FROM comment
        WHERE resource_id = #{resourceId}
          AND audit_status = 1
          AND deleted = 0
    </select>

    <!-- 根据ID查询评论 -->
    <select id="selectById" resultMap="CommentResultMap">
        SELECT *
        FROM comment
        WHERE id = #{id}
          AND deleted = 0
    </select>

    <!-- 插入评论 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comment (comment_id, user_id, resource_id, content, score, like_count, audit_status, ctime, deleted)
        VALUES (#{commentId}, #{userId}, #{resourceId}, #{content}, #{score}, #{likeCount}, #{auditStatus}, #{ctime}, #{deleted})
    </insert>

    <!-- 根据CommentId逻辑删除评论 -->
    <update id="deleteByCommentId">
        UPDATE comment
        SET deleted = 1
        WHERE comment_id = #{commentId}
    </update>

    <!-- 根据CommentId查询评论 -->
    <select id="selectByCommentId" resultMap="CommentResultMap">
        SELECT *
        FROM comment
        WHERE comment_id = #{commentId}
          AND deleted = 0
    </select>

    <!-- 检查用户是否已对该资源评论过 -->
    <select id="selectByUserAndResource" resultMap="CommentResultMap">
        SELECT *
        FROM comment
        WHERE user_id = #{userId}
          AND resource_id = #{resourceId}
          AND deleted = 0
        LIMIT 1
    </select>

    <!-- 根据评论ID查询评论 -->
    <select id="findByCommentId" parameterType="string" resultMap="CommentResultMap">
        SELECT *
        FROM comment
        WHERE comment_id = #{commentId}
    </select>

    <!-- 根据评论ID更新评论 -->
    <update id="updateByCommentId" parameterType="io.github.jacorycyjin.smartlibrary.backend.entity.Comment">
        UPDATE comment
        <set>
            <if test="content != null">content = #{content},</if>
            <if test="score != null">score = #{score},</if>
            <if test="auditStatus != null">audit_status = #{auditStatus},</if>
            <if test="rejectionReason != null">rejection_reason = #{rejectionReason},</if>
            <if test="deleted != null">deleted = #{deleted},</if>
            mtime = NOW()
        </set>
        WHERE comment_id = #{commentId}
    </update>

    <!-- 统计评论数量 -->
    <select id="countByParams" parameterType="map" resultType="java.lang.Long">
        SELECT COUNT(*) as count
        FROM comment
        <where>
            <if test="deleted != null">
                AND deleted = #{deleted}
            </if>
            <if test="auditStatus != null">
                AND audit_status = #{auditStatus}
            </if>
            <if test="resourceId != null and resourceId != ''">
                AND resource_id = #{resourceId}
            </if>
            <if test="userId != null and userId != ''">
                AND user_id = #{userId}
            </if>
        </where>
    </select>

    <!-- 管理员查询评论列表（关联用户名和资源标题） -->
    <select id="searchComments" parameterType="map" resultMap="AdminCommentResultMap">
        SELECT 
            c.*,
            u.username,
            r.title as resource_title
        FROM comment c
        LEFT JOIN user u ON c.user_id = u.user_id
        LEFT JOIN resource r ON c.resource_id = r.resource_id
        <where>
            <if test="keyword != null and keyword != ''">
                AND c.content LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="username != null and username != ''">
                AND u.username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="resourceId != null and resourceId != ''">
                AND c.resource_id = #{resourceId}
            </if>
            <if test="userId != null and userId != ''">
                AND c.user_id = #{userId}
            </if>
            <if test="auditStatus != null">
                AND c.audit_status = #{auditStatus}
            </if>
            <if test="deleted != null">
                AND c.deleted = #{deleted}
            </if>
        </where>
        ORDER BY c.ctime DESC
    </select>

    <!-- 统计用户的评论数量 -->
    <select id="countByUserId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM comment
        WHERE user_id = #{userId}
          AND audit_status = 1
          AND deleted = 0
    </select>
</mapper>
