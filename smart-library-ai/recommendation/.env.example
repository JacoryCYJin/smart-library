# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=smart_library

# 推荐算法参数
SIMILARITY_THRESHOLD=0.1
TOP_N_SIMILAR=20
TOP_N_RECOMMEND=10

# 行为权重
WEIGHT_BROWSE=1.0
WEIGHT_FAVORITE=3.0
WEIGHT_COMMENT=5.0

# 评分归一化
MAX_BROWSE_COUNT=10
COMMENT_SCORE_SCALE=10.0

# Redis 缓存（可选）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
CACHE_EXPIRE_SECONDS=86400
